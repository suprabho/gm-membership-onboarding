# ── Google Analytics 4 ────────────────────────────────────────────────────────
# Measurement ID from GA Admin → Data Streams (format: G-XXXXXXXXXX). Leave unset
# locally to keep GA silent — track() falls back to console logging in dev.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Learnyst (existing) ───────────────────────────────────────────────────────
# Override when pointing at a staging school. Defaults to production.
NEXT_PUBLIC_LEARNYST_BASE_URL=https://learn.greenmentor.academy

# ── Lead sheet (Google Sheets via Apps Script web app) ────────────────────────
# Deploy the Apps Script in docs/lead-sheet-setup.md as a Web App and paste its
# /exec URL here. The browser never sees this — /api/lead proxies to it server
# -side. Leave unset locally to log leads to the console instead of a sheet.
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXXXXXX/exec

# Optional shared secret — must match SHARED_SECRET in the Apps Script. Blocks
# spam if the /exec URL ever leaks. Leave blank to disable the check.
SHEETS_WEBHOOK_SECRET=3OP5h8f4TEXBMgXzP3jGYoZbi5ewTmEA

# ── Razorpay (payment seam) ───────────────────────────────────────────────────
# 1) Create a test-mode account and grab the API keys from:
#    https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Same KEY_ID exposed to the browser so the Razorpay Checkout SDK can init.
# NEVER expose KEY_SECRET — only the public key id.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# 2) Create a webhook in the dashboard pointed at
#    https://<your-host>/api/razorpay/webhook
#    Subscribe to: subscription.activated, subscription.charged,
#    subscription.cancelled, subscription.halted, subscription.completed,
#    payment.failed. Copy the webhook secret here.
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 3) Create two Razorpay plans (Subscriptions → Plans → Create plan) — one
#    monthly, one annual — at the amounts in lib/data/plans.ts (₹2,499/mo and
#    ₹1,999/mo billed yearly = ₹23,988/yr). Copy each `plan_…` id here.
#    Naming convention: RAZORPAY_PLAN_<UPPERCASE_PLAN_ID>_<MONTHLY|ANNUAL>
RAZORPAY_PLAN_MEMBERSHIP_MONTHLY=plan_xxxxxxxxxxxxxx
RAZORPAY_PLAN_MEMBERSHIP_ANNUAL=plan_xxxxxxxxxxxxxx
